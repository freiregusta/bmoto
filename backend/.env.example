# .env.example — variáveis de ambiente do backend.
# Copie para .env e preencha. Sem DATABASE_URL, roda com repositório in-memory.

# Banco (produção). Vazio = in-memory (dev).
DATABASE_URL=

# CORS: domínio(s) do front (Lovable). Separe múltiplos por vírgula.
CORS_ORIGINS=https://seu-app.lovable.app

# URL de redirect informada na oferta do leilão (entry_url).
ENTRY_URL=https://seu-app.lovable.app/formalizacao

# Segurança dos webhooks. Vazio = guard desligado (dev).
WEBHOOK_HMAC_SECRET=
WEBHOOK_IP_ALLOWLIST=
# Ex.: MTLS_REQUIRED_HEADER=X-Client-Verified=SUCCESS
MTLS_REQUIRED_HEADER=

# Workers (com Postgres, >1 é seguro).
WEB_CONCURRENCY=2
PORT=8000
